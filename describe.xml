<?xml version="1.0" encoding="UTF-8"?>
<!--
  describe.xml — VCF Content Factory vCommunity vSphere (Tier 2 Java SDK adapter).

  The vSphere/vCenter fork of the unified vCommunity adapter (native Java SDK
  rewrite of vmbro/VCF-Operations-vCommunity, Onur Yuzseven, CC-licensed). One
  of three paks the unified adapter was split into per
  designs/managementpacks/vcommunity-three-adapter-split.md; this pak owns the
  bulk vSphere collection surface read over the vim25 vCenter session (cluster
  HA/DRS/EVC, host advanced settings / VIB packages / install date / licensing /
  NIC uplinks, VM config / SCSI / snapshots, and the passive VMware-Tools
  Guest OS|Operating System|* path).

  Pure ARIA_OPS-style stitching: the only declared object kinds are the type=7
  adapter instance and the type=1 vCommunityWorld anchor. Every vCommunity|
  property/metric is pushed onto EXISTING foreign VMWARE ClusterComputeResource /
  HostSystem / VirtualMachine resources via the Suite API at runtime — those
  foreign kinds are intentionally NOT declared here (they are owned by the VMWARE
  adapter), exactly as the compliance reference adapter pushes onto VMWARE
  HostSystem without declaring it.

  Credential model: ONE credential kind ("vCenter Credential") with TWO fields —
  vCenter user + password (required). The vSphere pak has NO Windows guest
  credential: the in-guest guest-ops surface (Windows services / CSV OS-info /
  event logs) belongs to the vcommunity-os pak, so a vSphere-only admin sees only
  vCenter user/password (design §4 RBAC/UX win). The original adapter.py defines
  a single credential type ("vsphere_user"); here that kind carries only the two
  vCenter fields.

  This vSphere fork ships and references only the FOUR vSphere config files
  (esxi_advanced_system_settings, esxi_packages, vm_advanced_parameters,
  vm_options); the two Windows config files and the two Windows Monitoring enums
  belong to the vcommunity-os pak and were removed here (design §4).
-->
<AdapterKind xmlns="http://schemas.vmware.com/vcops/schema"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             key="vcfcf_vcommunity_vsphere"
             nameKey="1"
             version="1"
             xsi:schemaLocation="http://schemas.vmware.com/vcops/schema describeSchema.xsd">

  <CredentialKinds>
    <!-- vCenter Credential: vCenter user + password only (no Windows fields). -->
    <CredentialKind key="vsphere_user" nameKey="2">
      <CredentialField key="user" nameKey="3" type="string"
                       required="true" dispOrder="1"/>
      <CredentialField key="password" nameKey="4" type="string"
                       required="true" password="true" dispOrder="2"/>
    </CredentialKind>
  </CredentialKinds>

  <ResourceKinds>

    <!-- Adapter Instance (type=7): connection + the four vSphere config-file
         names. Binds the single vsphere_user credential. -->
    <ResourceKind key="vcfcf_vcommunity_vsphere" nameKey="5" type="7"
                  credentialKind="vsphere_user"
                  monitoringInterval="5">

      <!-- ===== Basic settings ===== -->
      <ResourceIdentifier key="host" nameKey="6" type="string"
                          required="true" dispOrder="1"/>
      <ResourceIdentifier key="esxi_adv_settings_config_file" nameKey="8"
                          type="string" required="false" dispOrder="2"
                          default="esxi_advanced_system_settings"/>
      <ResourceIdentifier key="esxi_vib_driver_config_file" nameKey="9"
                          type="string" required="false" dispOrder="3"
                          default="esxi_packages"/>
      <ResourceIdentifier key="vm_adv_settings_config_file" nameKey="10"
                          type="string" required="false" dispOrder="4"
                          default="vm_advanced_parameters"/>
      <ResourceIdentifier key="vm_configuration_config_file" nameKey="11"
                          type="string" required="false" dispOrder="5"
                          default="vm_options"/>

      <!-- ===== Advanced settings ===== -->
      <ResourceIdentifier key="port" nameKey="14" type="integer"
                          required="false" dispOrder="6" default="443"/>
      <ResourceIdentifier key="allowInsecure" nameKey="15" type="string"
                          required="false" dispOrder="7" default="false"
                          enum="true">
        <enum value="false" displayOrder="1"/>
        <enum value="true" displayOrder="2"/>
      </ResourceIdentifier>
    </ResourceKind>

    <!-- vCommunityWorld: synthetic INTERNAL collection anchor (health + ops).
         The vSphere pak stitches clusters, hosts, and VMs. -->
    <ResourceKind key="vCommunityWorld" nameKey="20" type="1">
      <ResourceIdentifier key="world_id" nameKey="21" type="string"
                          required="true" dispOrder="1"/>
      <ResourceGroup key="Summary" nameKey="22" instanced="false">
        <ResourceAttribute key="clusters_stitched" nameKey="23"
                           dataType="float" isProperty="false"
                           defaultMonitored="true"/>
        <ResourceAttribute key="hosts_stitched" nameKey="24"
                           dataType="float" isProperty="false"
                           defaultMonitored="true"/>
        <ResourceAttribute key="vms_stitched" nameKey="25"
                           dataType="float" isProperty="false"
                           defaultMonitored="true"/>
        <ResourceAttribute key="last_scan_timestamp" nameKey="29"
                           dataType="string" isProperty="true"/>
        <ResourceAttribute key="config_file_status" nameKey="30"
                           dataType="string" isProperty="true"/>
        <ResourceAttribute key="status" nameKey="31"
                           dataType="string" isProperty="true"/>
      </ResourceGroup>
    </ResourceKind>

  </ResourceKinds>

  <LicenseConfig enabled="false"/>

</AdapterKind>
